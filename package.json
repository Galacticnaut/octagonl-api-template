{
  "name": "@octagonl/api-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Octagonl API template – Express + TypeScript + Drizzle ORM",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run --exclude 'docs/**'",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "uuid": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
